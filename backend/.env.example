# --- Multi-provider fallback chain (see PROCURE_AI_ARCHITECTURE.md) ---
# Tried in this order: Groq -> Phi3 (local Ollama) -> Cerebras -> OpenRouter -> Demo mode.
# Each layer is skipped automatically if not configured/reachable. None are required —
# the app runs in demo mode with zero keys set.

# 1. Groq (PRIMARY) — free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# 2. Phi3 via local Ollama (FALLBACK 1) — install from https://ollama.ai, then:
#    ollama pull phi3 && ollama serve
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3

# 3. Cerebras (FALLBACK 2) — free key at https://cloud.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b

# 4. OpenRouter (FALLBACK 3) — free key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# Gemini API — unused by the active fallback chain; kept for reference
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Legacy OpenAI settings — unused by the active fallback chain
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
